# Database (docker compose up -d postgres 로 로컬 DB 실행)
DATABASE_URL="postgresql://archi:archi_dev@localhost:5433/archi_agent"

# LLM Provider (mock | anthropic)
LLM_PROVIDER="mock"
ANTHROPIC_API_KEY=""

# Search Provider (mock)
SEARCH_PROVIDER="mock"

# Image Provider (mock)
IMAGE_PROVIDER="mock"

# Object storage (local 디렉터리 기반 mock storage)
STORAGE_DIR=".storage"

# Dev auth (개발용 세션 시크릿)
AUTH_SECRET="dev-secret-change-me"
