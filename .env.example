# ─── Database ────────────────────────────────────────────────
# Supabase Postgres. 대시보드 > Project Settings > Database > Connection string.
# 런타임은 transaction pooler(6543), 마이그레이션은 session pooler(5432)를 쓴다.
# 비밀번호에 특수문자가 있으면 URL 인코딩 필요 ($ -> %24).
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# ─── Auth (Auth.js / NextAuth v5) ────────────────────────────
# openssl rand -base64 32 로 생성
AUTH_SECRET="change-me"
# 프로덕션 배포 도메인 (예: https://inshow-agent.vercel.app). 로컬은 비워도 됨.
AUTH_URL=""

# Google OAuth — https://console.cloud.google.com (OAuth 2.0 Client)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Kakao OAuth — https://developers.kakao.com (REST API 키 / Client Secret)
AUTH_KAKAO_ID=""
AUTH_KAKAO_SECRET=""

# Naver OAuth — https://developers.naver.com (애플리케이션 등록)
AUTH_NAVER_ID=""
AUTH_NAVER_SECRET=""

# 개발용 이메일 로그인 허용 (프로덕션에서 켜려면 "true")
ALLOW_DEV_LOGIN="true"

# ─── Providers (mock | 실제) ─────────────────────────────────
# Claude 계정 OAuth 연결 — Anthropic "Sign in with Claude" 클라이언트 ID
ANTHROPIC_OAUTH_CLIENT_ID=""

LLM_PROVIDER="mock"
ANTHROPIC_API_KEY=""
SEARCH_PROVIDER="mock"
IMAGE_PROVIDER="mock"

# Object storage (local 디렉터리 기반 mock storage)
STORAGE_DIR=".storage"
